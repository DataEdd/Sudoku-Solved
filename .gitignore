TODO
# Track only the ~2 MB Ground Example GT set under Examples/; the aug/
# directory (124 MB augmented data) and unsolved_dataset.zip (118 MB) stay
# out of git — they are bulk training artefacts, not part of the shipped
# benchmark dataset. The Ground Example images are what the reproducible
# benchmark harnesses and CI tests depend on, so they go in the repo.
Examples/*
!Examples/Ground Example/

# Generated artifacts
output/
reports/
tests/output/

# Internal project notes (not part of public repo)
docs/internal/

# Notebooks: only the 4 top-level pipeline deep-dive notebooks + README
# are tracked. All notebooks/<subdir>/ content is local-only (restored from
# git history for reference; not part of the public repo).
notebooks/*/

# Large data files
data/mnist/
data/chars74k/

# Results dataset: the 38 image copies under data/results_dataset/images/
# are gitignored because they're already tracked at Examples/Ground Example/.
# `python -m scripts.build_results_dataset` regenerates them before Kaggle
# upload. The dataset card, JSONL, and CSV metadata files ARE tracked.
data/results_dataset/images/

# Labeled dataset: the 2620 image copies under data/labeled_dataset/images/
# are ~124 MB and not part of the repo — they come from the upstream
# macfooty/sudoku-box-detection Kaggle dataset (itself an augmented
# redistribution of wichtounet/sudoku_dataset) and are regenerated from
# Examples/aug/ before a Kaggle upload by
# `python -m scripts.build_labeled_dataset`.
data/labeled_dataset/images/

# Cover image for Kaggle dataset page — generated by
# `python -m scripts.generate_cover_image`, not source of truth.
data/labeled_dataset/cover.png
*.ipynb_checkpoints/
research/
# CV sync — local notes, never commit
CV_NOTES.md

# Kaggle API token (new KGAT_* format). NEVER commit — anyone with this
# file can push to your Kaggle account. If it gets committed, rotate the
# token immediately at https://www.kaggle.com/settings/account → API.
api.md
kaggle.json

# Kaggle dataset metadata — per-user, local config. The source of truth
# for the dataset card is data/*/README.md (which is generated by
# scripts/build_*_dataset.py and tracked in git). The metadata file is
# only used by the kaggle CLI at upload time.
data/*/dataset-metadata.json

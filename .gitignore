# Track only the ~2 MB Ground Example GT set under Examples/; the aug/
# directory (124 MB augmented data) and unsolved_dataset.zip (118 MB) stay
# out of git — they are bulk training artefacts, not part of the shipped
# benchmark dataset. The Ground Example images are what the reproducible
# benchmark harnesses and CI tests depend on, so they go in the repo.
Examples/*
!Examples/Ground Example/

# Generated artifacts
output/
reports/
tests/output/

# Internal project notes (not part of public repo)
docs/internal/

# Notebooks: only the 4 top-level pipeline deep-dive notebooks + README
# are tracked. All notebooks/<subdir>/ content is local-only (restored from
# git history for reference; not part of the public repo).
notebooks/*/

# Large data files
data/mnist/
data/chars74k/

# Results dataset: the 38 image copies under data/results_dataset/images/
# are gitignored because they're already tracked at Examples/Ground Example/.
# `python -m scripts.build_results_dataset` regenerates them before Kaggle
# upload. The dataset card, JSONL, and CSV metadata files ARE tracked.
data/results_dataset/images/
*.ipynb_checkpoints/
research/
# CV sync — local notes, never commit
CV_NOTES.md
